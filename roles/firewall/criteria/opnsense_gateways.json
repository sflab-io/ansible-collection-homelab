{
  "type": "object",
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "desc": {
          "type": "string"
        },
        "int": {
          "type": "string"
        },
        "ip": {
          "type": "string",
          "pattern": "^(((?!25?[6-9])[12]\\d|[1-9])?\\d\\.?\\b){4}$"
        },
        "default": {
          "type": "boolean"
        },
        "far": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 255
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "monitor_disable": {
          "type": "boolean"
        },
        "monitor": {
          "type": "string",
          "pattern": "^(((?!25?[6-9])[12]\\d|[1-9])?\\d\\.?\\b){4}$"
        },
        "time_period": {
          "type": "integer",
          "minimum": 5
        },
        "force_down": {
          "type": "boolean"
        }
      },
      "required": ["int", "ip"]
    }
  }
}

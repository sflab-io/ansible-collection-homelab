{
  "type": "object",
  "propertyNames": {
    "pattern": "^([0-9A-Fa-f]{2}:){5}([0-9A-Fa-f]{2})$"
  },
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "desc": {
          "type": "string"
        },
        "subnet": {
          "type": "string"
        },
        "ip": {
          "type": "string",
          "pattern": "^(((?!25?[6-9])[12]\\d|[1-9])?\\d\\.?\\b){4}$"
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["ip"]
    }
  }
}

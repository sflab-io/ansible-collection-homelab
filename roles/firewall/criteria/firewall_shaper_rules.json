{
  "type": "object",
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "pipe": {
          "type": "string"
        },
        "queue": {
          "type": "string"
        },
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "int": {
          "type": "string"
        },
        "int2": {
          "type": "string"
        },
        "src": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "src_port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "string"
            }
          ]
        },
        "dst": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "dst_port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "string"
            }
          ]
        },
        "dir": {
          "type": "string",
          "enum": ["in", "out"]
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}

{
  "type": "object",
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "seq": {
          "type": "integer"
        },
        "int": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "src_port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "string"
            }
          ]
        },
        "dst": {
          "type": "string"
        },
        "dst_port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "string"
            }
          ]
        },
        "target": {
          "oneOf": [
            {
              "type": "string",
              "pattern": ".*ip$"
            },
            {
              "type": "string",
              "pattern": "^(((?!25?[6-9])[12]\\d|[1-9])?\\d\\.?\\b){4}$"
            }
          ]
        },
        "target_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}

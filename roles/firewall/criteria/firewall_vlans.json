{
  "type": "object",
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "parent": {
          "type": "string"
        },
        "vlan": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4094
        },
        "device": {
          "type": "string",
          "pattern": "^vlan0.*"
        }
      },
      "required": ["parent", "vlan"]
    }
  }
}

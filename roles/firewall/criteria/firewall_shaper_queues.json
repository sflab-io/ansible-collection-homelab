{
  "type": "object",
  "patternProperties": {
    "^.*": {
      "type": "object",
      "properties": {
        "pipe": {
          "type": "string"
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "mask": {
          "type": "string",
          "enum": ["none", "src-ip", "dst-ip"]
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["pipe"]
    }
  }
}
